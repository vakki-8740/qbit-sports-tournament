rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Settings - Anyone can read, admin can write
    match /settings/{key} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tournaments - Anyone can read, authenticated can write
    match /tournaments/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Joined Players - Anyone can read, authenticated can create
    match /joined_players/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if false;
    }

    // Transactions - Authenticated can read own + create
    match /transactions/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Polls - Anyone can read, authenticated can write
    match /polls/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Poll Votes - Anyone can read, authenticated can create
    match /poll_votes/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // Users - Authenticated can read/write
    match /users/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
